<?xml version="1.0" encoding="UTF-8"?>
<opml version="2.0">
  <head>
    <title>DBMS Digest — input feeds</title>
    <!-- Curated RSS/Atom feeds scanned each run, across all languages.
         Verified 2026-06-20 (browser-confirmed where noted):
           [ok]      fetches as plain XML with a normal fetch.
           [browser] live feed, but our plain fetch returns empty/blocked - read it with the
                     Claude-in-Chrome browser tools. Do NOT drop these; the source is good,
                     only the plain-fetch path fails. (Lobsters confirmed live via browser.)
         Maintain like the other source lists: add confirmed feeds, retire only truly dead ones. -->
  </head>
  <body>
    <outline text="Aggregators (English)">
      <outline type="rss" text="Hacker News - database (>=50 pts) [ok]" xmlUrl="https://hnrss.org/newest?q=database&amp;points=50"/>
      <outline type="rss" text="Lobsters - databases tag [browser - confirmed live]" xmlUrl="https://lobste.rs/t/databases.rss"/>
    </outline>
    <outline text="Community (browser - .rss blocklisted/empty for plain fetch)">
      <outline type="rss" text="r/databasedevelopment [browser]" xmlUrl="https://www.reddit.com/r/databasedevelopment/.rss"/>
    </outline>
    <outline text="Research">
      <outline type="rss" text="arXiv cs.DB [ok]" xmlUrl="https://rss.arxiv.org/rss/cs.DB"/>
    </outline>
    <outline text="Chinese [zh] - browser-rendered; no clean RSS, heavy vendor-PR (filter hard)">
      <!-- Browser-confirmed 2026-06-20: modb.pro renders fine via Claude-in-Chrome.
           cn.pingcap.com never reaches document_idle (long-polling) - get_page_text times out;
           use read_page (screenshot) or modb instead. Chinese DB media is dense vendor PR
           (Dameng, Kingbase, GoldenDB, Highgo, ...) - drop it; mine OceanBase/TiDB/PolarDB
           research and genuine internals posts. -->
      <outline type="link" text="modb.pro - 墨天轮 DB news [browser - confirmed]" htmlUrl="https://www.modb.pro/dbNews"/>
      <outline type="link" text="PingCAP/TiDB CN blog [browser - slow; use read_page]" htmlUrl="https://cn.pingcap.com/blog/"/>
    </outline>
  </body>
</opml>
